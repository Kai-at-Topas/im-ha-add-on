# Home Assistant add-on specific
# Ignore local data and databases, but keep the core configuration structural files
*.local
*.db
logs/
data/

# Track your project files, but ignore local dynamic JSON data dumps
# (e.g., if you have /data/options.json locally)
data/*.json
options.json

# Python package cache
.pytest_cache/
.mypy_cache/
.coverage
*.egg-info/
*.egg
**/__pycache__/

# Python virtual environments
.venv/
venv/

# Development / Secrets
.env
.env.local
.env.*.local
.env.*
.env-local
.env-*

# Docker
*.docker

# Node
node_modules

# Frontend build output (regenerated by `npm run build` / the Docker image build)
frontend/dist/